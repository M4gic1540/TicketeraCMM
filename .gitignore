# =====================================================================
# ASDP - .gitignore
# =====================================================================

# --- Node / NestJS / React ---
node_modules/
dist/
build/
.next/
out/
coverage/
*.tsbuildinfo
.turbo/

# --- Env / secretos ---
.env
.env.local
.env.*.local
!.env.example

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Docker / infra ---
infra/postgres/data/
infra/rabbitmq/data/
*.pid

# --- Prisma ---
prisma/*.db
prisma/migrations/.tmp/

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# --- Testing ---
.nyc_output/
junit.xml

# --- Package managers ---
.npm/
.yarn/
.pnp.*

# --- LaTeX (informes) ---
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk