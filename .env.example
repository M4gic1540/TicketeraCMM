# =====================================================================
# ASDP - Variables de entorno para orquestación local (docker-compose)
# Copiar como .env antes de levantar el stack.
# =====================================================================

# --- Gateway ---
GATEWAY_PORT=80
GATEWAY_DASHBOARD_PORT=8080

# --- PostgreSQL ---
POSTGRES_USER=asdp
POSTGRES_PASSWORD=asdp_dev_password
POSTGRES_DB=asdp_db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=asdp_dev_password
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=asdp
RABBITMQ_PASSWORD=asdp_dev_password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- Observabilidad (opcional, profile "observability") ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3300
GRAFANA_ADMIN_PASSWORD=admin
LOKI_PORT=3100

# --- JWT (usado luego por identity-service) ---
JWT_SECRET=change_me_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=change_me_too
JWT_REFRESH_EXPIRATION=7d
